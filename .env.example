# ─── URL pública de la app ────────────────────────────────────────────────────
# Sin trailing slash. Se usa para CORS, trusted origins y los snippets curl.
# Ejemplo: https://deploy.example.com
APP_URL=https://app.example.com

# Puerto que Nginx expone en el host (por defecto 80)
PORT=80

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Clave secreta para firmar sesiones y tokens.
# Genera una con: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ─── Admin inicial ────────────────────────────────────────────────────────────
# Se crea automáticamente la primera vez que arranca el backend.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=

# ─── SSO / Keycloak (opcional) ───────────────────────────────────────────────
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
# Discovery URL del realm: https://keycloak.example.com/realms/<realm>
SSO_ISSUER=
